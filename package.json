{
  "name": "skypulse-express",
  "version": "0.1.0",
  "description": "SkyPulse backend - TypeScript/Express port",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test dist-test/tests/**/*.test.js",
    "prestart": "npm run build",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "node-mocks-http": "^1.16.2",
    "typescript": "^5.8.3"
  }
}
